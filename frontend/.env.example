# ==============================================================================
# MYLAW.COM - FRONTEND ENVIRONMENT VARIABLES (TEMPLATE)
# ==============================================================================
# INSTRUCTIONS: Copy this file to '.env' and fill in the actual values.
# DO NOT commit the actual '.env' file to version control.

# 1. BACKEND API ROUTING
# Local Development: http://localhost:8080/api/v1
# Production (K8s Ingress): https://api.mylaw.com/v1
REACT_APP_API_URL=http://localhost:8080/api/v1

# 2. FEATURE FLAGS (Optional toggle for new features)
REACT_APP_ENABLE_VIDEO_KYC=false
REACT_APP_ENABLE_AI_LEGAL_ASSISTANT=true

# 3. ANALYTICS / MONITORING (e.g., Sentry, Google Analytics)
REACT_APP_SENTRY_DSN=
REACT_APP_GA_MEASUREMENT_ID=